// ────────────────────────────────────────────────────────────────────────────────
// Prisma Schema for SIAP LOGISTIK BENCANA
// Disaster Logistics Management System
// ────────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ROLES ──────────────────────────────────────────────────────────────────────
model Role {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users User[]

  @@map("roles")
}

// ─── USERS ──────────────────────────────────────────────────────────────────────
model User {
  id          Int       @id @default(autoincrement())
  name        String
  email       String    @unique
  password    String
  role_id     Int
  instansi_id Int?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  role     Role      @relation(fields: [role_id], references: [id])
  instansi Instansi? @relation(fields: [instansi_id], references: [id])

  permintaan  PermintaanLogistik[]
  distribusi  Distribusi[]

  @@index([email])
  @@map("users")
}

// ─── INSTANSI ───────────────────────────────────────────────────────────────────
model Instansi {
  id              Int      @id @default(autoincrement())
  nama_instansi   String
  jenis_instansi  String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  users  User[]
  gudang Gudang[]

  @@map("instansi")
}

// ─── GUDANG ─────────────────────────────────────────────────────────────────────
model Gudang {
  id          Int      @id @default(autoincrement())
  nama_gudang String
  instansi_id Int
  alamat      String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  instansi Instansi @relation(fields: [instansi_id], references: [id])

  stok_logistik StokLogistik[]
  barang_masuk  BarangMasuk[]
  distribusi    Distribusi[]

  @@map("gudang")
}

// ─── JENIS LOGISTIK ─────────────────────────────────────────────────────────────
model JenisLogistik {
  id         Int      @id @default(autoincrement())
  nama_jenis String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  barang_logistik BarangLogistik[]

  @@map("jenis_logistik")
}

// ─── SATUAN ─────────────────────────────────────────────────────────────────────
model Satuan {
  id          Int      @id @default(autoincrement())
  nama_satuan String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  barang_logistik BarangLogistik[]

  @@map("satuan")
}

// ─── BARANG LOGISTIK ────────────────────────────────────────────────────────────
model BarangLogistik {
  id               Int      @id @default(autoincrement())
  nama_barang      String
  jenis_logistik_id Int
  satuan_id        Int
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  jenis_logistik JenisLogistik @relation(fields: [jenis_logistik_id], references: [id])
  satuan         Satuan        @relation(fields: [satuan_id], references: [id])

  stok_logistik      StokLogistik[]
  barang_masuk       BarangMasuk[]
  permintaan_detail  PermintaanDetail[]
  distribusi_detail  DistribusiDetail[]

  @@map("barang_logistik")
}

// ─── STOK LOGISTIK ──────────────────────────────────────────────────────────────
model StokLogistik {
  id           Int       @id @default(autoincrement())
  barang_id    Int
  gudang_id    Int
  jumlah       Int       @default(0)
  expired_date DateTime?
  kondisi      String    @default("baik")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  barang BarangLogistik @relation(fields: [barang_id], references: [id])
  gudang Gudang         @relation(fields: [gudang_id], references: [id])

  @@index([barang_id])
  @@index([gudang_id])
  @@map("stok_logistik")
}

// ─── BARANG MASUK ───────────────────────────────────────────────────────────────
model BarangMasuk {
  id              Int       @id @default(autoincrement())
  tanggal_masuk   DateTime
  barang_id       Int
  jumlah          Int
  gudang_id       Int
  sumber_logistik String
  supplier        String
  catatan         String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  barang BarangLogistik @relation(fields: [barang_id], references: [id])
  gudang Gudang         @relation(fields: [gudang_id], references: [id])

  @@index([barang_id])
  @@index([gudang_id])
  @@map("barang_masuk")
}

// ─── KENDARAAN ──────────────────────────────────────────────────────────────────
model Kendaraan {
  id              Int      @id @default(autoincrement())
  nama_kendaraan  String
  nomor_polisi    String
  kapasitas       String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  distribusi Distribusi[]

  @@map("kendaraan")
}

// ─── BENCANA ────────────────────────────────────────────────────────────────────
model Bencana {
  id               Int      @id @default(autoincrement())
  jenis_bencana    String
  lokasi           String
  latitude         Float?
  longitude        Float?
  tanggal          DateTime
  jumlah_pengungsi Int      @default(0)
  jumlah_korban    Int      @default(0)
  status           String   @default("Tanggap Darurat")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  permintaan PermintaanLogistik[]

  @@index([tanggal])
  @@map("bencana")
}

// ─── PERMINTAAN LOGISTIK ────────────────────────────────────────────────────────
model PermintaanLogistik {
  id          Int      @id @default(autoincrement())
  bencana_id  Int
  pemohon_id  Int
  status      String   @default("pending")
  tanggal     DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  bencana    Bencana  @relation(fields: [bencana_id], references: [id])
  pemohon    User     @relation(fields: [pemohon_id], references: [id])
  detail     PermintaanDetail[]
  distribusi Distribusi[]

  @@index([status])
  @@map("permintaan_logistik")
}

// ─── PERMINTAAN DETAIL ──────────────────────────────────────────────────────────
model PermintaanDetail {
  id             Int      @id @default(autoincrement())
  permintaan_id  Int
  barang_id      Int
  jumlah         Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  permintaan PermintaanLogistik @relation(fields: [permintaan_id], references: [id], onDelete: Cascade)
  barang     BarangLogistik     @relation(fields: [barang_id], references: [id])

  @@map("permintaan_detail")
}

// ─── DISTRIBUSI ─────────────────────────────────────────────────────────────────
model Distribusi {
  id             Int      @id @default(autoincrement())
  permintaan_id  Int
  gudang_id      Int
  tanggal_kirim  DateTime
  kendaraan_id   Int
  petugas_id     Int
  status         String   @default("pending")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  permintaan PermintaanLogistik @relation(fields: [permintaan_id], references: [id])
  gudang     Gudang             @relation(fields: [gudang_id], references: [id])
  kendaraan  Kendaraan          @relation(fields: [kendaraan_id], references: [id])
  petugas    User               @relation(fields: [petugas_id], references: [id])
  detail     DistribusiDetail[]
  penerimaan PenerimaanLogistik[]

  @@map("distribusi")
}

// ─── DISTRIBUSI DETAIL ──────────────────────────────────────────────────────────
model DistribusiDetail {
  id            Int      @id @default(autoincrement())
  distribusi_id Int
  barang_id     Int
  jumlah        Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  distribusi Distribusi     @relation(fields: [distribusi_id], references: [id], onDelete: Cascade)
  barang     BarangLogistik @relation(fields: [barang_id], references: [id])

  @@map("distribusi_detail")
}

// ─── PENERIMAAN LOGISTIK ────────────────────────────────────────────────────────
model PenerimaanLogistik {
  id              Int      @id @default(autoincrement())
  distribusi_id   Int
  tanggal_terima  DateTime @default(now())
  petugas_posko   String
  catatan         String?
  dokumentasi     String?
  latitude        Float?
  longitude       Float?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  distribusi Distribusi @relation(fields: [distribusi_id], references: [id])

  @@map("penerimaan_logistik")
}
